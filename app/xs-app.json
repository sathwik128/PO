{
    "welcomeFile": "/purord/index.html",
    "authenticationMethod": "route",
    "routes": [
        {
            "source": "^/purord/(.*)$",
            "target": "$1",
            "localDir": "purord/webapp",
            "authenticationType": "xsuaa"
        },
        {
            "source": "^/odata/v2/(.*)$",
            "target": "/odata/v2/$1",
            "destination": "srv-api",
            "authenticationType": "xsuaa"
        },
        {
            "source": "^/odata/v4/(.*)$",
            "target": "/odata/v4/$1",
            "destination": "srv-api",
            "authenticationType": "xsuaa"
        }
    ],
    "logout": {
        "logoutEndpoint": "/my/logout",
        "logoutPage": "https://www.google.com"
    },
    "errorPage": [
        {
            "status": [
                400,
                401,
                402
            ],
            "path": "/custom-err-4xx.html"
        },
        {
            "status": 501,
            "path": "/custom-err-501.html"
        }
    ]
}